# Anthropic API — OPTIONAL
# If not set, the app uses the built-in rule-based analysis engine (no LLM required).
# If set, the Claude AI agent is used instead for richer analysis.
# ANTHROPIC_API_KEY=sk-ant-...

# Database — SQLite local (default, no setup needed)
DATABASE_URL=sqlite:///./data.db

# Cache TTL in hours
CACHE_TTL_HOURS=24
